{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeGitInstructions": false,
  "permissions": {
    "deny": [ "Bash(git push *)" ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "code-review@samu-plugins": true
  },
  "extraKnownMarketplaces": {
    "samu-plugins": {
      "source": {
        "source": "github",
        "repo": "scristobal/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "github.com",
        "*.githubusercontent.com",
        "ghcr.io",
        "*.ghcr.io",
        "npmjs.org",
        "*.npmjs.org",
        "pypi.org",
        "*.pythonhosted.org",
        "crates.io",
        "*.crates.io",
        "*.rust-lang.org",
        "*.apple.com",
        "swiftpackageindex.com",
        "*.cocoapods.org",
        "*.google.com",
        "*.apache.org",
        "*.gradle.org",
        "*.brew.sh",
        "*.anthropic.com",
        "json.schemastore.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.cache"
      ],
      "denyWrite": [
        "./.git",
        "~/.bashrc",
        "~/.zshrc",
        "~/.zprofile",
        "~/.bash_profile",
        "~/.profile",
        "~/.ssh",
        "~/.gnupg",
        "~/.aws"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.docker",
        "~/.kube",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.config/gh",
        "~/.bash_history",
        "~/.zsh_history",
        "*.env"
      ]
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
