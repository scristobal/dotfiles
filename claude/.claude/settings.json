{
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(which *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(man *)",
      "Bash(type *)",
      "Bash(whoami)",
      "Bash(tree *)",
      "Bash(diff *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(uname *)",
      "Bash(ps *)",
      "Bash(uptime)",
      "Bash(sw_vers *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(otool *)",
      "Bash(nm *)",
      "Bash(strings *)",
      "Bash(dwarfdump *)",
      "Bash(size *)",
      "Bash(pagestuff *)",
      "Bash(objdump *)",
      "Bash(readelf *)",
      "Bash(hexdump *)",
      "Bash(xxd *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(sudo *)",
      "Bash(pip *)",
      "Bash(npm *)",
      "Bash(brew *)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "code-review@samu-plugins": true,
    "codex-review@samu-plugins": true,
    "lsp-servers@samu-plugins": true
  },
  "extraKnownMarketplaces": {
    "samu-plugins": {
      "source": {
        "source": "github",
        "repo": "scristobal/claude-plugins"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyWrite": [
        "~/"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
