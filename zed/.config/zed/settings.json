{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "hover_popover_enabled": true,
  "which_key": {
    "enabled": true
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "show_edit_predictions": true,
  "format_on_save": "off",
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle"
  },
  "auto_install_extensions": {
    "nordic-theme": true,
    "html": true,
    "lua": true,
    "playdate": true,
    "make": true,
    "toml": true
  },
  "show_completions_on_input": true,
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "default_profile": "write"
  },
  "auto_signature_help": true,
  "inlay_hints": {
    "toggle_on_modifiers_press": {
      "control": true
    }
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "project_panel": {
    "dock": "left",
    "indent_size": 12,
    "indent_guides": {
      "show": "never"
    }
  },
  "title_bar": {
    "show_branch_status_icon": true
  },
  "scrollbar": {
    "diagnostics": "none"
  },
  "minimap": {
    "show": "never"
  },
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 13,
  "buffer_line_height": "comfortable",
  "ui_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Monobiome Dark"
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_smartcase_find": false,
    "highlight_on_yank_duration": 200,
    "custom_digraphs": {}
  },
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font",
    "line_height": "standard"
  },
  "file_types": { "GLSL": ["*.glsl"] },
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "node_modules/.bin/biome",
          "arguments": [
            "format",
            "--write",
            "--use-server",
            "--stdin-file-path=something.ts",
            "<",
            "{buffer_path}"
          ]
        }
      }
    },
    "Python": {
      "language_servers": [
        "ty",
        "!basedpyright",
        "..."
      ]
    }
  }
}
